---
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/ui";

import IconMail from "./icons/IconMail.astro";
import IconLinkedin from "./icons/IconLinkedin.astro";
import IconGithub from "./icons/IconGithub.astro";
import IconMapPin from "./icons/IconMapPin.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="hero" class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container">
    <p class="hero__tag">{t("hero.tag")}</p>

    <h1 class="hero__name">
      Fernando<br />
      <em>Hirschfeld</em>
    </h1>

    <p class="hero__meta">
      <span>{t("hero.role")}</span>
      <span class="hero__dot" aria-hidden="true"></span>
      <span>{t("hero.at")} Synapxix</span>
    </p>

    <p class="hero__bio">{t("hero.bio")}</p>

    <p class="hero__studying">
      {t("hero.studying")} — <span>{t("hero.studyAt")}</span>
    </p>

    <div class="hero__actions">
      <a href="#projects" class="btn-primary">{t("hero.cta")}</a>
      <a href="#contact"  class="btn-ghost">{t("hero.ctaContact")} →</a>
    </div>

    <div class="hero__links">
      <a
        href="https://github.com/ferdev777"
        target="_blank"
        rel="noreferrer noopener"
        class="hero__link"
      >
        <IconGithub class="hero-icon" aria-hidden="true" /> github.com/ferdev777
      </a>
      <a
        href="https://linkedin.com/in/fernando-hirschfeld"
        target="_blank"
        rel="noreferrer noopener"
        class="hero__link"
      >
        <IconLinkedin class="hero-icon" aria-hidden="true" /> linkedin.com/in/fernando-hirschfeld
      </a>
      <a href="mailto:ferdeveloperwork@gmail.com" class="hero__link">
        <IconMail class="hero-icon" aria-hidden="true" /> ferdeveloperwork@gmail.com
      </a>
      <span class="hero__link">
        <IconMapPin class="hero-icon" aria-hidden="true" /> {t("hero.location")}
      </span>
    </div>
  </div>
</section>
