---
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/ui";

import IconUser from "./icons/IconUser.astro";
import IconBriefcase from "./icons/IconBriefcase.astro";
import IconStar from "./icons/IconStar.astro";
import IconGlobe from "./icons/IconGlobe.astro";
import IconFolder from "./icons/IconFolder.astro";
import IconMessageSquare from "./icons/IconMessageSquare.astro";
import IconGithub from "./icons/IconGithub.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const esHref = "/";
const enHref = "/en/";
---

<header class="navbar">
  <div class="container">
    <nav class="navbar__nav" aria-label="Navegación principal">
      <a href="#hero"       class="navbar__link"><IconUser class="nav-icon" />{t("nav.about")}</a>
      <a href="#experience" class="navbar__link"><IconBriefcase class="nav-icon" />{t("nav.experience")}</a>
      <a href="#featured"   class="navbar__link"><IconStar class="nav-icon" />{t("nav.featured")}</a>
      <a href="#websites"   class="navbar__link"><IconGlobe class="nav-icon" />{t("nav.websites")}</a>
      <a href="#projects"   class="navbar__link"><IconFolder class="nav-icon" />{t("nav.projects")}</a>
      <a href="#contact"    class="navbar__link"><IconMessageSquare class="nav-icon" />{t("nav.contact")}</a>
    </nav>

    <div class="navbar__right">
      <!-- Language switch: links reales, sin JS -->
      <div class="lang-switch" role="group" aria-label="Cambiar idioma">
        <a href={esHref} aria-current={lang === "es" ? "true" : "false"}>
          <span class="lang-flag" aria-hidden="true">🇪🇸</span> ES
        </a>
        <a href={enHref} aria-current={lang === "en" ? "true" : "false"}>
          <span class="lang-flag" aria-hidden="true">🇺🇸</span> EN
        </a>
      </div>

      <a
        href="https://github.com/ferdev777"
        target="_blank"
        rel="noreferrer noopener"
        class="navbar__link"
      >
        <IconGithub class="nav-icon" /> GitHub
      </a>
    </div>
  </div>
</header>
